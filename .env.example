# ---- GEAR Moz quickstart config -------------------------------------------
# Copy this to `.env`. The defaults work as-is; nothing is required to start.
#   cp .env.example .env

# Local model. For Ollama, this is the model tag.
# Default below is small (~500MB) so first-run is fast — bump to qwen3:4b
# (~2.5GB) or larger once you have the stack working. Tags:
# https://ollama.com/library  (e.g. qwen3:4b, qwen3:8b, llama3.2:3b)
LOCAL_MODEL=qwen3:0.6b

# Model that grades eval `llm-rubric` assertions. When unset, defaults to your
# LOCAL_MODEL so the suite runs with zero API keys. That's convenient but means
# the model is grading its own work — and a small model will sometimes mark a
# self-contradictory answer as PASS. For stricter scoring, point it elsewhere:
#   GRADER_MODEL=ollama:chat:qwen3:4b                              # bigger local grader
#   GRADER_MODEL=openai:gpt-4o-mini                                # OpenAI grader (needs OPENAI_API_KEY)
#   GRADER_MODEL=anthropic:messages:claude-haiku-4-5-20251001      # Claude grader (needs ANTHROPIC_API_KEY)
# Format is Promptfoo's provider string (provider:[type:]model).
# GRADER_MODEL=

# Gateway admin/master key. Used by the helper scripts as the bearer token.
# Any non-empty string is fine for local dev — change it if you expose the gateway.
GATEWAY_MASTER_KEY=sk-gear-moz-dev-change-me

# Where the gateway listens (leave as-is for local).
GATEWAY_URL=http://localhost:8000


# ---- OPTIONAL: compare local against a frontier model ----------------------
# 1) Add a key below.
# 2) Uncomment the matching provider in gateway/config.example.yml
# 3) Uncomment the frontier block in evals/promptfooconfig.yaml
# 4) make restart eval
# OPENAI_API_KEY=
# ANTHROPIC_API_KEY=


# ---- OPTIONAL: auto-download a llamafile (the Mozilla way) -----------------
# If set, `make model` downloads this single-file model into ./models/
# Find model llamafiles at https://github.com/mozilla-ai/llamafile (or Mozilla on Hugging Face).
# LLAMAFILE_URL=
